{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "adhkar",
  "version": "0.1.0",
  "identifier": "com.github.zizouhuweidi.adhkar",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Adhkar",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "description": "Adhkar - Dhikr and Dua App",
      "args": [
        {
          "name": "mode",
          "short": "m",
          "takesValue": true,
          "description": "Run mode: gui or daemon",
          "possibleValues": ["gui", "daemon"]
        }
      ],
      "subcommands": {
        "list": {
          "description": "List categories or dhikr",
          "args": [
            {
              "name": "type",
              "takesValue": true,
              "description": "What to list: categories, dhikr",
              "possibleValues": ["categories", "dhikr"]
            },
            {
              "name": "category",
              "short": "c",
              "takesValue": true,
              "description": "Category slug (for listing dhikr)"
            }
          ]
        },
        "show": {
          "description": "Show a specific dhikr",
          "args": [
            {
              "name": "id",
              "takesValue": true,
              "description": "Dhikr ID"
            }
          ]
        },
        "search": {
          "description": "Search dhikr",
          "args": [
            {
              "name": "query",
              "takesValue": true,
              "description": "Search query"
            }
          ]
        },
        "random": {
          "description": "Show a random dhikr"
        },
        "history": {
          "description": "Show notification history",
          "args": [
            {
              "name": "limit",
              "takesValue": true,
              "description": "Number of entries to show"
            }
          ]
        },
        "config": {
          "description": "Get or set configuration",
          "args": [
            {
              "name": "action",
              "takesValue": true,
              "description": "get or set",
              "possibleValues": ["get", "set"]
            },
            {
              "name": "key",
              "takesValue": true,
              "description": "Setting key"
            },
            {
              "name": "value",
              "takesValue": true,
              "description": "Setting value (for set)"
            }
          ]
        }
      }
    }
  }
}
